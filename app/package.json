{
  "name": "figure-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"eslint.config.mjs\" \"dependency-cruiser.cjs\" \"vitest.config.ts\" \"scripts/**/*.mjs\" \"src/**/*.test.ts\" \"../README.md\" \"../docs/**/*.md\" \"../.github/workflows/*.yml\" \".*.{js,cjs,mjs,json}\" \"*.{json,ts,mjs,cjs}\"",
    "format:write": "prettier --write \"eslint.config.mjs\" \"dependency-cruiser.cjs\" \"vitest.config.ts\" \"scripts/**/*.mjs\" \"src/**/*.test.ts\" \"../README.md\" \"../docs/**/*.md\" \"../.github/workflows/*.yml\" \".*.{js,cjs,mjs,json}\" \"*.{json,ts,mjs,cjs}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:types": "tsc --noEmit",
    "check:dead-code": "knip",
    "check:boundaries": "dependency-cruiser --config dependency-cruiser.cjs src",
    "check:backend:lint": "python3 -m ruff check ../backend",
    "check:backend:types": "pyright ../backend",
    "check:backend:compile": "python3 -m py_compile ../backend/app.py ../backend/runtime.py ../backend/codex_bridge.py ../backend/codex_store.py ../backend/routes/codex.py ../backend/services/figures.py ../backend/services/workspace.py",
    "check:backend:test": "PYTHONPATH=.. python3 -m pytest ../backend/tests",
    "check:backend:deps": "pip-audit -r ../backend/requirements.txt",
    "check:backend": "npm run check:backend:lint && npm run check:backend:types && npm run check:backend:compile && npm run check:backend:test",
    "check:frontend:deps": "npm audit --audit-level=high",
    "check:frontend": "npm run format:check && npm run check:types && npm run lint && npm run check:dead-code && npm run check:boundaries && npm run test && npm run build",
    "check:security": "npm run check:frontend:deps && npm run check:backend:deps",
    "check": "npm run check:frontend && npm run check:backend",
    "fix": "npm run format:write && eslint \"src/**/*.{ts,tsx}\" --fix",
    "audit:size": "node ./scripts/report-size.mjs"
  },
  "dependencies": {
    "@uiw/color-convert": "^2.10.1",
    "@uiw/react-color-shade-slider": "^2.10.1",
    "@uiw/react-color-wheel": "^2.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.26.0",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^15.15.0",
    "knip": "^6.6.1",
    "prettier": "^3.5.3",
    "pyright": "^1.1.400",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.31.1",
    "vite": "^8.0.9",
    "vitest": "^3.1.2"
  }
}
